# =============================================================================
# HYBRID RAG - ENV TEMPLATE
# =============================================================================

FASTAPI_ROOT_PATH=/rag

# Technical RAG (Milvus)
MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=rag_documents

# Legal GraphRAG (Neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

RAG_DATA_DIR=/app/data
RAG_DOCS_DIR=/app/data/documents
RAG_NORMATIVA_SOURCE_DIR=/app/normativa

RAG_LLM_PROVIDER=openai
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_TEMPERATURE=0.1

RAG_ROUTER_MODEL=gpt-4o-mini
RAG_ROUTER_TEMPERATURE=0.0
RAG_ROUTER_USE_LLM=true
RAG_ROUTER_SCORE_MARGIN=2.0

RAG_ORCH_PROBE_TOP_K=4
RAG_ORCH_TECH_MIN_SCORE=0.80
RAG_ORCH_TECH_MIN_CHUNKS=2
RAG_ORCH_LEGAL_MIN_SCORE=0.20
RAG_ORCH_LEGAL_MIN_CHUNKS=2
RAG_ORCH_LEGAL_KEYWORD_COVERAGE=0.30

RAG_LEGAL_OVERFETCH_K=32
RAG_LEGAL_RERANKER_ENABLED=true
RAG_LEGAL_RERANKER_ENDPOINT=
RAG_LEGAL_RERANKER_MODEL=bge-reranker-v2-m3
RAG_LEGAL_RERANKER_TIMEOUT_MS=2500
RAG_LEGAL_RERANKER_TOP_N=10
RAG_LEGAL_GROUNDING_ENABLED=true
RAG_LEGAL_GROUNDING_SIM_THRESHOLD=0.35
RAG_LEGAL_GROUNDING_LLM_FALLBACK=true
RAG_LEGAL_QREL_THRESHOLD=0.26
RAG_LEGAL_COMBINED_THRESHOLD=0.46
RAG_LEGAL_EVIDENCE_MAX_ITEMS=2
RAG_LEGAL_SNIPPET_MAX_CHARS=220
RAG_LEGAL_REQUIRE_NUMERIC_OVERLAP_FOR_NUMERIC_QUERY=true

RAG_EMBED_MODEL=intfloat/multilingual-e5-base
RAG_EMBED_DEVICE=auto
RAG_CHUNK_MAX_TOKENS=530
RAG_CHUNK_OVERLAP=50

RAG_API_HOST=0.0.0.0
RAG_API_PORT=8001
RAG_STARTUP_MAX_RETRIES=20
RAG_STARTUP_RETRY_INTERVAL_SECONDS=2
RAG_MILVUS_CONNECT_TIMEOUT_SECONDS=5
RAG_NEO4J_CONNECT_TIMEOUT_SECONDS=5

OPENAI_API_KEY=<YOUR_KEY>
